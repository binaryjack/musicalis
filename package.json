{
  "name": "musicalist",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "launch": "node launch.js",
    "launch:build": "node launch.js --build",
    "launch:clean": "node launch.js --clean",
    "compile": "tsc -b",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist node_modules/.vite",
    "reset": "npm run clean && npm install",
    "fix": "eslint . --fix",
    "start": "vite preview --host --open"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "@types/redux-mock-store": "^1.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "redux": "^5.0.1",
    "redux-saga": "^1.4.2",
    "reselect": "^5.1.1",
    "tone": "^15.1.22",
    "vexflow": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cypress": "^15.13.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.1"
  }
}
